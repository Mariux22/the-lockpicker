<div class="lp-game-root">

  <h2 class="lp-title">
    {{#if isTrap}}{{localize "LOCKPICKING.TrapTitle"}}{{else}}{{localize "LOCKPICKING.Title"}}{{/if}}
    {{#if showPhase}}<span class="lp-phase-badge">{{localize "LOCKPICKING.Phase" n=phaseNumber}}</span>{{/if}}
  </h2>

  <div class="lp-meta">
    <div><b>{{actorName}}</b> {{#if isTrap}}{{localize "LOCKPICKING.AttemptsDisarm"}}{{else}}{{localize "LOCKPICKING.Attempts"}}{{/if}}</div>

    <div class="lp-tags-row">
      <span class="lp-tag lp-tag--dc">DC: {{dc}}</span>
      <span class="lp-tag lp-tag--bonus">Bonus: {{bonus}}</span>
      {{#if isTrap}}<span class="lp-tag lp-tag--trap">⚠ {{localize "LOCKPICKING.TrapTag"}} – {{damage}} {{damageType}}</span>{{/if}}
      {{#if extremeMode}}<span class="lp-tag lp-tag--extreme">⚡ {{localize "LOCKPICKING.ExtremeMode"}}</span>{{/if}}
      {{#if reliableTalent}}<span class="lp-tag lp-tag--reliable">{{localize "LOCKPICKING.ReliableTalent"}}</span>{{/if}}
      {{#if advantage}}<span class="lp-tag lp-tag--advantage">🟢 Advantage</span>
      {{else if disadvantage}}<span class="lp-tag lp-tag--bad">🔴 Disadvantage</span>
      {{else}}<span class="lp-tag lp-tag--neutral">⚖️ Normal</span>{{/if}}
    </div>

    <div class="lp-expl-shield">
      {{#if bonusBreakdown}}
        <p class="lp-expl">{{localize "LOCKPICKING.BonusBreakdown"}} DEX {{numberFormat bonusBreakdown.dexMod sign=true}}{{#if bonusBreakdown.profPart}} + {{bonusBreakdown.profLabel}} {{numberFormat bonusBreakdown.profPart sign=true}}{{/if}} = <b>{{numberFormat bonusBreakdown.totalBonus sign=true}}</b></p>
      {{/if}}
      {{#if reliableInfo}}
        <p class="lp-expl">
          {{{localize "LOCKPICKING.Explanation.Bonus" label=bonusBreakdown.profLabel bonus=reliableInfo.trainingBonus}}}
          {{#if reliableInfo.hasReliable}}{{{localize "LOCKPICKING.Explanation.Reliable" mistakes=reliableInfo.allowedMistakes}}}{{else}}{{{localize "LOCKPICKING.Explanation.NoReliable"}}}{{/if}}
        </p>
      {{/if}}
      {{#if isTrap}}<p class="lp-expl lp-expl--trap-warning">{{{localize "LOCKPICKING.Explanation.TrapWarning" damage=damage damageType=damageType}}}</p>{{/if}}
      <p class="lp-expl lp-expl--last">{{{localize "LOCKPICKING.Explanation.Instructions"}}}</p>
    </div>
  </div>

  <div class="lp-section">
    <div class="lp-section-label">{{localize "LOCKPICKING.Progress"}}</div>
    <div class="lp-timer-bar"><div class="lp-timer-fill"></div><div class="lp-timer-text">0.0s</div></div>
    <div class="lp-mistakes-info"></div>
  </div>

  <div class="lp-section">
    <div class="lp-section-label">{{localize "LOCKPICKING.Sequence"}}</div>
    <div class="lp-sequence-steps"></div>
  </div>

  <div class="lp-current-key-box">
    <div class="lp-current-key-icon">
      <div class="lp-current-key-pick"></div>
    </div>
    <div class="lp-current-key-arrow">
      <div class="lp-current-key-icon-inner" data-key=""></div>
    </div>
    <div class="lp-current-key-label">{{localize "LOCKPICKING.CurrentKey"}}</div>
  </div>

  <div class="lp-status-text">{{localize "LOCKPICKING.Ready"}}</div>

  <div class="lp-buttons">
    <button class="lp-btn lp-btn--primary" data-action="start-game">{{localize "LOCKPICKING.Start"}}</button>
    <button class="lp-btn" data-action="cancel-game">{{localize "LOCKPICKING.Cancel"}}</button>
  </div>

</div>
